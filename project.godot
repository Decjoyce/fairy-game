; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="fairy-game"
run/main_scene="uid://ckuw7ho3cogrs"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=240
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://jy6sni2hxcl8"

[autoload]

GridMapPathfinding="res://addons/grid_map_pathfinding/grid_map_pathfinding.gd"
Debug="*res://scenes/_managers/debugger/debugger.tscn"
Impact_Manager="*res://scenes/_managers/impact_manager/impact_manager.tscn"
GM="*uid://sfbx2b7nrctr"
TEMPSaveGameHandler="*uid://cpncffjgoewdh"
OMT="*uid://bfjbajm1402m3"
EffectsPlayer="*uid://ck8x0eqy5wlqv"

[debug]

gdscript/warnings/unassigned_variable=0
gdscript/warnings/unused_variable=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[debug_draw_3d]

settings/addon_root_folder="res://addons/grid_map_pathfinding/debug_draw_3d"

[display]

window/size/initial_position_type=3

[editor_plugins]

enabled=PackedStringArray("res://addons/extras_sprites/plugin.cfg", "res://addons/grid_map_pathfinding/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "purple",
"res://assets/": "red",
"res://scenes/": "teal",
"res://scenes/__playground_scenes/": "teal",
"res://scenes/__prototyping/": "teal",
"res://scenes/_levels/main_level/": "orange",
"res://scripts/": "yellow",
"res://zzz_GARBAGE/": "gray"
}

[filesystem]

import/blender/enabled=false

[global_group]

Player="Player (duh)"
Interactables=""
DrawBoards=""
debug_PickableObjects=""
