; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="fairy-game"
run/main_scene="uid://bw2ceq76kc2yc"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GridMapPathfinding="res://addons/grid_map_pathfinding/grid_map_pathfinding.gd"
Debug="*res://scenes/__prototyping/debugger/debugger.tscn"
Impact_Manager="*res://scenes/_managers/impact_manager/impact_manager.tscn"

[debug]

gdscript/warnings/unassigned_variable=0
gdscript/warnings/unused_variable=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[debug_draw_3d]

settings/addon_root_folder="res://addons/grid_map_pathfinding/debug_draw_3d"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[editor_plugins]

enabled=PackedStringArray("res://addons/grid_map_pathfinding/plugin.cfg")

[filesystem]

import/blender/enabled=false

[global_group]

Player="Player (duh)"
Interactables=""
DrawBoards=""
debug_PickableObjects=""
MainCamera=""
GMPF="GridMapPathFind"
EnemyCombatHand=""

